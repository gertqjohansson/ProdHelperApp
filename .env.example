# Copy this file to .env and fill in the values from your Azure Relay namespace.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# The namespace host, e.g. myrelayns.servicebus.windows.net
VITE_RELAY_NAMESPACE=myrelayns.servicebus.windows.net

# The Hybrid Connection name you created inside the namespace
VITE_HC_NAME=my-hybrid-connection

# Name of a Shared Access Policy that has "Send" rights (or "Listen,Send,Manage")
VITE_SAS_KEY_NAME=RootManageSharedAccessKey

# The primary or secondary key value for that policy
VITE_SAS_KEY=REPLACE_WITH_YOUR_KEY

# WARNING: this key ends up in the browser bundle. Fine for local testing;
# for a real deployment, move the SAS token creation into a backend instead.
