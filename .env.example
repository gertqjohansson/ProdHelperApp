# Copy to client/.env and fill in real values. These are baked into the
# client bundle at BUILD time (Vite inlines import.meta.env.VITE_* values),
# so they must be set before running `npm run build`, not just at runtime.

# Relay namespace, e.g. myrelayns.servicebus.windows.net
VITE_RELAY_NAMESPACE=your-relay-namespace.servicebus.windows.net

# The Hybrid Connection name you created inside the namespace
VITE_HC_NAME=your-hybrid-connection-name

# Name of a Shared Access Policy that has "Send" rights
VITE_SAS_KEY_NAME=your-sas-policy-name

# The primary or secondary key value for that policy
VITE_SAS_KEY=your-sas-policy-key

# WARNING: this key ends up in the browser bundle. Fine for local testing;
# for a real deployment, move the SAS token creation into a backend instead.
